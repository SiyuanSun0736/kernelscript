flowchart TD
    A["Packet arrives at NIC"] --> B["XDP hook runs early<br/>before full network stack"]
    B --> C["KernelScript @xdp program<br/>packet_filter(ctx)"]
    C --> D["Read ctx->data and ctx->data_end"]
    D --> E["Compute packet_size"]
    E --> F{"packet_size > 1500?"}
    F -->|Yes| G["Return XDP_DROP<br/>drop packet early"]
    F -->|No| H["Return XDP_PASS<br/>continue through stack"]
    I["Userspace main"] --> J["load(packet_filter)"]
    J --> K["attach(prog, eth0, 0)"]
    K --> B

classDef nodeStyle fill:#ffffff,stroke:#000000,stroke-width:2px;
class A,B,C,D,E,F,G,H,I,J,K nodeStyle
